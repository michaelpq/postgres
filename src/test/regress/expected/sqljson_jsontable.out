                               )
                       ),
                       nested path 'strict $.c[*]' as pc columns (
                               c text format json path '$',
                               nested path 'strict $[*]' as pc1 columns (
                                       c1 int path '$'
                               )
                       )
               )
               --plan default(outer, cross)
               plan(p outer ((pb inner pb1) cross (pc outer pc1)))
       ) jt;
