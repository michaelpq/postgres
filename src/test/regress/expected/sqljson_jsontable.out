 2 |  2 |    3 | 3 |      |   
 2 |  2 |      |   |    1 | 10
 2 |  2 |      |   |    2 |   
 2 |  2 |      |   |    3 | 20
 3 |  3 |    1 | 1 |      |   
 3 |  3 |    2 | 2 |      |   
