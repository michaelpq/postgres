select
       jt.*, b1 + 100 as b
from
       json_table (jsonb
               '[
                       {"a":  1,  "b": [[1, 10], [2], [3, 30, 300]], "c": [1, null, 2]},
                       {"a":  2,  "b": [10, 20], "c": [1, null, 2]},
                       {"x": "3", "b": [11, 22, 33, 44]}
                ]',
               '$[*]' as p
               columns (
                       n for ordinality,
                       a int path 'lax $.a' default -1 on error,
                       nested path 'strict $.b[*]' as pb columns (
